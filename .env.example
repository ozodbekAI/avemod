APP_NAME=WB Data Core Backend
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=.*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wb_data_core
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT_SECONDS=60
DATABASE_POOL_RECYCLE_SECONDS=1800

JWT_SECRET_KEY=replace-with-strong-access-secret
JWT_REFRESH_SECRET_KEY=replace-with-strong-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
WB_TOKEN_ENCRYPTION_KEY=replace-with-fernet-key

ENABLE_SCHEDULER=true
SCHEDULER_TIMEZONE=UTC

DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
HEAVY_ENDPOINT_CACHE_TTL_SECONDS=600
MONEY_RESPONSE_SNAPSHOT_REFRESH_MINUTES=10
MONEY_RESPONSE_SNAPSHOT_MAX_STALE_MINUTES=30
MONEY_RESPONSE_SNAPSHOT_ACTIVE_DAYS=7
MONEY_RESPONSE_SNAPSHOT_REFRESH_MAX_SPECS_PER_ACCOUNT=80
MONEY_RESPONSE_SNAPSHOT_REFRESH_MIN_ACCESS_COUNT=2

WB_HTTP_TIMEOUT=30
WB_HTTP_RETRY_ATTEMPTS=3
WB_HTTP_RETRY_BACKOFF_SECONDS=1
ANALYTICS_FUNNEL_BATCH_SIZE=20
FINANCE_DETAIL_PAGES_PER_RUN=3
STOCKS_PENDING_TASK_MAX_AGE_HOURS=6
SYNC_RUNNING_CURSOR_STALE_HOURS=6

# AI Operator optional modules. Safe defaults must not perform marketplace writes.
CHECKER_BASE_URL=
CHECKER_SERVICE_TOKEN=
CHECKER_TIMEOUT_SECONDS=5
CHECKER_ACCOUNT_STORE_MAPPING={}
WB_CHECKER_DATA_PATH=data/wb_checker
CHECKER_AI_ENABLED=false
CHECKER_VISION_ENABLED=false
CHECKER_MIN_TITLE_LENGTH=40
CHECKER_MAX_TITLE_LENGTH=60
CHECKER_MIN_DESCRIPTION_LENGTH=1000
CHECKER_MAX_DESCRIPTION_LENGTH=1800
CHECKER_MIN_PHOTOS_COUNT=3
CHECKER_RECOMMENDED_PHOTOS_COUNT=6
CHECKER_PRODUCT_DNA_PHOTOS_COUNT=4

REPUTATION_ENABLED=false
REPUTATION_BASE_URL=
REPUTATION_SHOP_MAP={}
REPUTATION_AI_DEFAULT_ENABLED=false
ENABLE_REPUTATION_PUBLISH=false
ENABLE_REPUTATION_WRITE_ACTIONS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

# Photo Studio image generation. Leave GEMINI_API_KEY empty to keep manual-only mode.
PHOTO_STORAGE_ROOT=.local/photo_studio
PHOTO_SIGNED_URL_TTL_SECONDS=900
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_MODEL_FALLBACK=gemini-2.5-flash-image
GEMINI_IMAGE_TIMEOUT_SECONDS=240
GEMINI_IMAGE_MAX_RETRIES=2

CLAIMS_ENABLED=false
CLAIMS_BASE_URL=
ENABLE_CLAIMS_SUBMIT=false

GROUPING_ENABLED=false
ENABLE_GROUPING_MERGE=false
ENABLE_CARD_AUTO_APPLY=false

# Final staging acceptance audit. Values must be provided only in the shell or
# deployment secret store; never commit real tokens here.
BASE_URL=
ADMIN_ACCESS_TOKEN=
SELLER_ACCESS_TOKEN=
SELLER_OWN_ACCOUNT_ID=
FORBIDDEN_ACCOUNT_ID=
SELLER_TEST_NM_ID=
AUDIT_DATE_FROM=
AUDIT_DATE_TO=
